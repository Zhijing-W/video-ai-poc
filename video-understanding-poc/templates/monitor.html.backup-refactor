  <script>
    // ===== 模式切换：监控模式 vs 技术模式 =====
    const monitorView = document.getElementById("monitor-view");
    const techView = document.getElementById("tech-view");
    const btnMonitorMode = document.getElementById("btnMonitorMode");
    const btnTechMode = document.getElementById("btnTechMode");

    // 默认技术模式（流程图已完成，监控模式待开发）
    let currentMode = localStorage.getItem("view-mode") || "tech";
    function switchMode(mode){
      currentMode = mode;
      localStorage.setItem("view-mode", mode);
      if (mode === "monitor"){
        monitorView.style.display = "block";
        techView.style.display = "none";
        btnMonitorMode.classList.add("active");
        btnTechMode.classList.remove("active");
      } else {
        monitorView.style.display = "none";
        techView.style.display = "block";
        btnMonitorMode.classList.remove("active");
        btnTechMode.classList.add("active");
      }
    }
    btnMonitorMode.addEventListener("click", () => switchMode("monitor"));
    btnTechMode.addEventListener("click", () => switchMode("tech"));
    switchMode(currentMode);  // 初始化视图

    // ===== 共享业务逻辑和 DOM 元素 =====
    const $ = (id) => document.getElementById(id);
    const video = $("video"), canvas = $("canvas"), stage = $("stage");
    let stream = null, timer = null, inFlight = false, refDataUri = null;
    let stats = { frames: 0, match: 0, alert: 0, llm: 0, skipped: 0 };
    let activeCompare = null;           // {mode,target,reference} —— 点「开始比对」后才有值
    let frameStore = {}, frameSeq = 0;  // 存每帧的图像+结果，供日志点击预览
    let cycle = null;                   // 当前监控周期（开始监控→停止监控）
    let lastCounts = null;              // 上一帧 YOLO counts（传给门控判断进出场）
    let lastLlmTs = 0;                  // 上次真正调用 gpt-4o 的时间戳（冷却/心跳）
    let cruiseBuf = [];                 // YOLO 巡航期缓冲的帧（审计发现偏差时回填重判）
    let cruiseCount = 0;                // 巡航帧计数器（用于审计间隔节流）
    let lastLlmSig = null, lastLlmData = null;   // #1 复用：上次真调 gpt-4o 的签名 + 完整结果
    let lastAuditCount = 0, lastCruiseVerdict = null, cruiseFlip = false;  // #2 颜色触发审计状态
    const BACKFILL_MAX = 4;             // 单次回填最多重判的帧数（防长时间冻结实时画面）

    function auditEvery(){ return Math.max(2, Math.min(60, parseInt($("auditEvery").value) || 8)); }

    // ===== 交互式流水线：节点弹层 + 实时高亮当前流经步骤 =====
    const STAGES = ["input","yolo","gate","compile","cruise","llm","result"];
    let camOn = false, cooldownTimer = null;   // 摄像头开关状态 / 结束后 5s 冷静期计时器
    function closeAllPops(){}   // 已改为节点内联控件，无浮层（保留空函数兼容旧调用）

    // —— 可插拔模型/方案选择（架构演示）——
    // 当前后端实跑 YOLOv8m + gpt-4o；其余为方案占位，切换后随请求透传，后端接入后即生效。
    let yoloModelSel = "yolov8m", llmModelSel = "gpt-4o";
    function wireModelSelect(id, pillId, setter, planned){
      const sel = $(id), pill = $(pillId);
      if (!sel) return;
      sel.addEventListener("change", () => {
        const v = sel.value, txt = sel.options[sel.selectedIndex].text;
        setter(v);
        if (pill) pill.textContent = txt.split(" ·")[0];
        const isPlanned = /规划/.test(txt);
        if (isPlanned) logRow("attention", "🧩 已切换为「" + txt + "」：当前后端尚未接入，实跑仍为默认方案；该选择会随请求透传，接入后即生效。", false, null);
        else logRow("normal", "🧩 模型方案 → " + txt, false, null);
      });
    }
    wireModelSelect("yoloModel", "pill-yolo", v => yoloModelSel = v);
    wireModelSelect("llmModel", "pill-llm", v => llmModelSel = v);

    // ===== 监控模式与技术模式共享逻辑 =====
    // 策略：两个模式共享同一个video元素（技术模式的video），监控模式通过按钮代理和数据同步实现功能复用
    if ($("btnCam-dash")) {
      // 按钮代理：监控模式按钮触发技术模式按钮
      $("btnCam-dash").onclick = () => $("btnCam").click();
      $("btnFile-dash").onclick = () => $("btnFile").click();
      $("fileInput-dash").onchange = (e) => { const dt = new DataTransfer(); Array.from(e.target.files).forEach(f => dt.items.add(f)); $("fileInput").files = dt.files; $("fileInput").dispatchEvent(new Event("change")); };
      $("btnStart-dash").onclick = () => $("btnStart").click();
      $("btnStop-dash").onclick = () => $("btnStop").click();
      $("btnCompare-dash").onclick = () => $("btnCompare").click();
      $("btnCompareStop-dash").onclick = () => $("btnCompareStop").click();
      
      // 配置同步：监控模式控件改变时同步到技术模式
      $("yoloModel-dash").onchange = () => { $("yoloModel").value = $("yoloModel-dash").value; $("yoloModel").dispatchEvent(new Event("change")); };
      $("llmModel-dash").onchange = () => { $("llmModel").value = $("llmModel-dash").value; $("llmModel").dispatchEvent(new Event("change")); };
      $("boxToggle-dash").onchange = () => $("boxToggle").checked = $("boxToggle-dash").checked;
      $("gateToggle-dash").onchange = () => $("gateToggle").checked = $("gateToggle-dash").checked;
      $("cruiseToggle-dash").onchange = () => $("cruiseToggle").checked = $("cruiseToggle-dash").checked;
      $("intervalVal-dash").oninput = () => $("intervalVal").value = $("intervalVal-dash").value;
      $("intervalUnit-dash").onchange = () => $("intervalUnit").value = $("intervalUnit-dash").value;
      $("auditEvery-dash").oninput = () => $("auditEvery").value = $("auditEvery-dash").value;
      $("target-dash").oninput = () => $("target").value = $("target-dash").value;
      document.querySelectorAll('input[name="cmode-dash"]').forEach(r => {
        r.onchange = () => { const target = document.querySelector(`input[name="cmode"][value="${r.value}"]`); if (target) target.checked = true; };
      });
      
      // video元素复用：移除dash模式的独立video，复用技术模式的video
      const dashStage = $("stage-dash");
      const videoDash = $("video-dash");
      if (videoDash) videoDash.remove();  // 移除占位video
      const boxesDash = $("boxes-dash");
      if (boxesDash) boxesDash.remove();  // 移除占位svg
      
      // 把技术模式的stage内容移到监控模式（保持两个stage独立但共享video引用）
      // HTML里已经有scan-dash/hud-dash/corner-dash/empty-dash，不需要重复创建
      dashStage.insertBefore(video, dashStage.firstChild);   // video移到最前
      dashStage.insertBefore($("boxes"), video.nextSibling);  // svg紧跟video
      
      // 切换模式时移动video位置
      const originalSwitchMode = switchMode;
      switchMode = function(mode){
        originalSwitchMode(mode);
        if (mode === "monitor") {
          // 移动到dash
          if (dashStage && video.parentElement !== dashStage) {
            dashStage.insertBefore(video, dashStage.firstChild);
            dashStage.insertBefore($("boxes"), video.nextSibling);
          }
        } else if (mode === "tech") {
          // 移回tech
          const techStage = $("stage");
          if (techStage && video.parentElement !== techStage) {
            techStage.insertBefore(video, techStage.firstChild);
            const techBoxes = document.getElementById("boxes");
            if (techBoxes) techStage.insertBefore(techBoxes, video.nextSibling);
          }
        }
      };
      
      // 初始化：根据当前模式放置video
      if (currentMode === "monitor") {
        dashStage.insertBefore(video, dashStage.firstChild);
        dashStage.insertBefore($("boxes"), video.nextSibling);
      }
    }

    // 点亮一条路径：active=本帧实际流经的节点数组；相邻活跃节点间的连线流动（移动光点+虚线）
    let stageClear = null;
    function lightPath(active){
      STAGES.forEach(s => { const n = $("nd-" + s); if (n) n.classList.toggle("active", active.includes(s)); });
      document.querySelectorAll(".conn-h,.conn-v").forEach(a => {
        const f = a.dataset.from, t = a.dataset.to;
        a.classList.toggle("flow", active.includes(f) && active.includes(t));
      });
      if (stageClear) clearTimeout(stageClear);
      stageClear = setTimeout(dimPath, Math.max(900, intervalMs() + 400));  // 帧间隔后自动熄灭
    }
    function dimPath(){
      STAGES.forEach(s => { const n = $("nd-" + s); if (n) n.classList.remove("active"); });
      document.querySelectorAll(".conn-h.flow,.conn-v.flow").forEach(a => a.classList.remove("flow"));
    }
    function nstat(id, txt){
      const e = $("st-" + id); if (e) e.textContent = txt;
      if (id === "result"){ const r = $("resultMini"); if (r) r.textContent = txt; }
    }
    function countsSummary(yolo){
      const c = (yolo && yolo.counts) || {};
      const ks = Object.keys(c);
      return ks.length ? ks.map(k => k + "×" + c[k]).join(" ") : "无目标";
    }
    // 输入节点内的小预览（让架构图的「输入框」实时显示当前帧）
    function updateMini(dataUri){ const m = $("ndImg"); if (m) m.src = dataUri; }

    // —— YOLO 检测框可视化（叠加在 live feed 上）——
    const COLOR_HEX = { red:"#ef4444", orange:"#f97316", yellow:"#eab308", green:"#22c55e",
      blue:"#3b82f6", purple:"#a855f7", pink:"#ec4899", white:"#e5e7eb", gray:"#9ca3af",
      black:"#4b5563", brown:"#a16207" };
    function colorHex(c){ return c ? (COLOR_HEX[c] || null) : null; }

    // 视频在 stage 内的实际渲染矩形（object-fit:contain 会有黑边，需还原）
    function videoRect(){
      const vw = video.videoWidth, vh = video.videoHeight;
      if (!vw || !vh) return null;
      
      // 根据video当前所在的容器计算
      const container = video.parentElement;
      if (!container) return null;
      
      const Sw = container.clientWidth, Sh = container.clientHeight;
      const scale = Math.min(Sw / vw, Sh / vh);
      const w = vw * scale, h = vh * scale;
      return { x:(Sw - w) / 2, y:(Sh - h) / 2, w, h, Sw, Sh };
    }
    function sameBox(a, b){
      return a && b && a.length === 4 && b.length === 4 && a.every((v, i) => Math.abs(v - b[i]) < 0.5);
    }
    function clearBoxes(){ 
      $("boxes").innerHTML = ""; 
      if ($("boxes-dash")) $("boxes-dash").innerHTML = "";
    }

    // 把 YOLO 框（capture 像素坐标）映射到屏幕，绘制矩形+标签；命中绿、目标候选橙、其余按 CV 主色
    function drawBoxes(yolo, opts){
      const svg = $("boxes");
      const svgDash = $("boxes-dash");
      
      if (!$("boxToggle").checked || !yolo || !yolo.detections || !yolo.img_w || !yolo.img_h){ 
        svg.innerHTML = ""; 
        if (svgDash) svgDash.innerHTML = "";
        return; 
      }
      const rect = videoRect();
      if (!rect){ 
        svg.innerHTML = ""; 
        if (svgDash) svgDash.innerHTML = "";
        return; 
      }
      
      const viewBox = `0 0 ${rect.Sw} ${rect.Sh}`;
      svg.setAttribute("viewBox", viewBox);
      if (svgDash) svgDash.setAttribute("viewBox", viewBox);
      
      const sx = rect.w / yolo.img_w, sy = rect.h / yolo.img_h;
      const plan = opts && opts.plan, matched = (opts && opts.matchedBoxes) || [];
      const parts = [];
      for (const d of yolo.detections){
        const b = d.box; if (!b || b.length < 4) continue;
        const x = rect.x + b[0] * sx, y = rect.y + b[1] * sy;
        const w = (b[2] - b[0]) * sx, h = (b[3] - b[1]) * sy;
        const isTarget = plan && plan.yolo_class && d.label === plan.yolo_class;
        const isMatched = matched.some(mb => sameBox(mb, b));
        let stroke = colorHex(d.color) || "#38bdf8", sw = 2, dash = "";
        if (isMatched){ stroke = "#22c55e"; sw = 3; }
        else if (isTarget){ stroke = "#f59e0b"; sw = 2.5; dash = "6 4"; }
        let label = `${d.label} ${Math.round((d.confidence || 0) * 100)}%`;
        if (d.color_zh) label += " ·" + d.color_zh;
        const tw = label.length * 7.4 + 10, ty = y > 16 ? y - 16 : y + 1;
        parts.push(
          `<rect x="${x.toFixed(1)}" y="${y.toFixed(1)}" width="${Math.max(0,w).toFixed(1)}" height="${Math.max(0,h).toFixed(1)}" `
          + `fill="none" stroke="${stroke}" stroke-width="${sw}"${dash ? ` stroke-dasharray="${dash}"` : ""} rx="3"/>`
          + `<rect x="${x.toFixed(1)}" y="${ty.toFixed(1)}" width="${tw.toFixed(1)}" height="15" fill="${stroke}" opacity="0.9" rx="2"/>`
          + `<text x="${(x + 4).toFixed(1)}" y="${(ty + 11).toFixed(1)}" font-size="11" font-family="monospace" fill="#0b0f14">${escapeHtml(label)}</text>`
        );
      }
      const html = parts.join("");
      svg.innerHTML = html;
      if (svgDash) svgDash.innerHTML = html;
    }

