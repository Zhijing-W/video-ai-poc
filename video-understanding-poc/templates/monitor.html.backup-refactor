<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>实时比对监控台 · Video Understanding</title>
  <style>
    :root{
      --bg:#f0eee6; --panel:#ffffff; --panel2:#faf9f4; --card:#f6f4ed; --line:#e7e3d8;
      --fg:#2b2a26; --muted:#85816f; --accent:#cc785c; --accent2:#b8623f;
      --ok:#2a9067; --warn:#bd8a2e; --alert:#c0392b; --idle:#cdc9bb;
      --stage:#1b1a17;
      --shadow:0 1px 2px rgba(50,46,38,.04),0 6px 18px rgba(50,46,38,.06);
      --shadow-lg:0 8px 30px rgba(50,46,38,.12);
      --mono:"SF Mono","Cascadia Mono","Consolas",ui-monospace,monospace;
      --serif:"Iowan Old Style","Palatino Linotype",Georgia,"Songti SC",serif;
    }
    *{box-sizing:border-box;}
    html,body{height:100%;}
    body{margin:0;
      font-family:system-ui,-apple-system,"Segoe UI","Microsoft YaHei",Roboto,Helvetica,Arial,sans-serif;
      background:var(--bg);color:var(--fg);font-size:14px;line-height:1.5;
      -webkit-font-smoothing:antialiased;}
    ::selection{background:rgba(204,120,92,.22);}
    /* 顶栏 */
    .topbar{display:flex;align-items:center;gap:16px;padding:14px 24px;
      border-bottom:1px solid var(--line);background:rgba(250,249,244,.86);backdrop-filter:blur(10px);
      position:sticky;top:0;z-index:10;}
    .brand{font-weight:600;letter-spacing:.1px;font-size:1.02rem;display:flex;align-items:center;gap:11px;color:var(--fg);font-family:var(--serif);}
    .brand .logo{width:30px;height:30px;border-radius:9px;
      background:linear-gradient(135deg,var(--accent),var(--accent2));display:grid;place-items:center;color:#fff;font-size:16px;box-shadow:0 2px 8px rgba(204,120,92,.35);}
    .live{margin-left:auto;display:flex;align-items:center;gap:8px;font-size:.82rem;color:var(--muted);}
    .led{width:9px;height:9px;border-radius:50%;background:var(--idle);}
    .led.on{background:var(--ok);animation:pulse 1.6s infinite;}
    .led.cooldown{background:var(--warn);animation:pulse 1s infinite;}
    @keyframes pulse{0%{box-shadow:0 0 0 0 rgba(42,144,103,.5)}70%{box-shadow:0 0 0 7px rgba(42,144,103,0)}100%{box-shadow:0 0 0 0 rgba(42,144,103,0)}}
    .clock{font-family:var(--mono);font-variant-numeric:tabular-nums;color:var(--muted);font-size:.82rem;}

    /* 布局 */
    .grid{display:grid;grid-template-columns:1.7fr 1fr;gap:16px;padding:16px;max-width:1500px;margin:0 auto;}
    @media(max-width:1000px){.grid{grid-template-columns:1fr;}}
    .panel{background:var(--panel);border:1px solid var(--line);border-radius:14px;padding:18px;box-shadow:var(--shadow);}
    .panel h2{margin:0 0 12px;font-size:.72rem;letter-spacing:1.2px;text-transform:uppercase;color:var(--muted);font-weight:600;}

    /* 视频区 */
    .stage{position:relative;background:var(--stage);border-radius:12px;overflow:hidden;aspect-ratio:16/9;border:1px solid var(--line);}
    .stage video{width:100%;height:100%;object-fit:contain;background:var(--stage);display:block;}
    .stage .scan{position:absolute;inset:0;pointer-events:none;
      background:linear-gradient(180deg,transparent 0%,rgba(204,120,92,.16) 50%,transparent 100%);opacity:0;}
    .stage.analyzing .scan{opacity:1;animation:scan 1.8s linear infinite;}
    @keyframes scan{0%{transform:translateY(-100%)}100%{transform:translateY(100%)}}
    .stage .boxes{position:absolute;inset:0;pointer-events:none;z-index:2;}
    .stage .hud{position:absolute;top:10px;left:10px;display:flex;gap:8px;flex-wrap:wrap;}
    .chip{font-size:.72rem;padding:3px 9px;border-radius:999px;background:rgba(0,0,0,.45);
      border:1px solid rgba(255,255,255,.18);color:#f3efe6;backdrop-filter:blur(4px);}
    .chip.src{border-color:var(--accent);color:#f3c9b8;}
    .stage .corner{position:absolute;top:10px;right:12px;font-size:.72rem;color:#e7e1d4;
      font-family:var(--mono);font-variant-numeric:tabular-nums;}
    .empty{position:absolute;inset:0;display:grid;place-items:center;color:#9b968a;font-size:.9rem;text-align:center;}

    /* 控件 */
    .controls{display:flex;flex-wrap:wrap;gap:8px;margin-top:14px;}
    button{background:#fff;color:var(--fg);border:1px solid var(--line);
      padding:8px 14px;border-radius:9px;font-weight:500;cursor:pointer;font-size:.84rem;
      font-family:inherit;transition:.15s;box-shadow:0 1px 1.5px rgba(50,46,38,.04);}
    button:hover:not(:disabled){border-color:#d8c3b4;background:#fbf7f3;}
    button:disabled{opacity:.45;cursor:not-allowed;}
    button.primary{background:var(--accent);color:#fff;border-color:var(--accent);box-shadow:0 2px 8px rgba(204,120,92,.28);}
    button.primary:hover:not(:disabled){background:var(--accent2);border-color:var(--accent2);}
    button.danger{background:transparent;border-color:rgba(192,57,43,.4);color:var(--alert);box-shadow:none;}
    button.danger:hover:not(:disabled){background:rgba(192,57,43,.08);border-color:var(--alert);}
    .field{margin-top:14px;}
    .field label{display:block;font-size:.76rem;color:var(--muted);margin-bottom:6px;}
    .field input[type=text],.field input[type=number],.field select,
    select,input[type=text],input[type=number]{
      width:100%;padding:9px 11px;background:#fff;color:var(--fg);
      border:1px solid var(--line);border-radius:9px;font-size:.86rem;
      font-family:inherit;outline:none;caret-color:var(--accent);transition:.15s;}
    input[type=text]:focus,input[type=number]:focus,select:focus{
      border-color:var(--accent);box-shadow:0 0 0 3px rgba(204,120,92,.16);}
    input::placeholder{color:#aaa597;}
    input[type=number]::-webkit-inner-spin-button,
    input[type=number]::-webkit-outer-spin-button{opacity:.6;}
    select{appearance:none;-webkit-appearance:none;cursor:pointer;
      background-image:linear-gradient(45deg,transparent 50%,var(--muted) 50%),linear-gradient(135deg,var(--muted) 50%,transparent 50%);
      background-position:calc(100% - 16px) center,calc(100% - 11px) center;
      background-size:5px 5px,5px 5px;background-repeat:no-repeat;padding-right:28px;}
    option{background:#fff;color:var(--fg);}
    .row{display:flex;gap:10px;}.row>*{flex:1;}
    .ref{display:flex;align-items:center;gap:10px;margin-top:8px;}
    .ref img{width:54px;height:54px;object-fit:cover;border-radius:8px;border:1px solid var(--line);background:#f1efe7;}
    .hint{font-size:.74rem;color:var(--muted);margin-top:6px;}

    /* 比对大卡 */
    .matchcard{border-radius:13px;padding:16px;text-align:center;border:1px solid var(--line);
      background:var(--card);transition:.2s;}
    .matchcard.match{border-color:var(--ok);background:rgba(42,144,103,.09);}
    .matchcard.nomatch{border-color:var(--line);}
    .matchcard.alert{border-color:var(--alert);background:rgba(192,57,43,.07);}
    .matchcard .big{font-size:1.5rem;font-weight:700;letter-spacing:.5px;margin:2px 0;}
    .matchcard .conf{font-size:.78rem;color:var(--muted);}
    .matchcard .reason{font-size:.82rem;color:#54514a;margin-top:8px;line-height:1.45;text-align:left;}

    .stats{display:grid;grid-template-columns:repeat(3,1fr);gap:8px;margin-top:14px;}
    .stat{background:var(--card);border:1px solid var(--line);border-radius:11px;padding:10px;text-align:center;}
    .stat .n{font-size:1.3rem;font-weight:700;font-family:var(--mono);font-variant-numeric:tabular-nums;}
    .stat .l{font-size:.68rem;color:var(--muted);letter-spacing:.3px;margin-top:2px;}

    .tags{display:flex;flex-wrap:wrap;gap:6px;margin-top:6px;}
    .tag{font-size:.74rem;padding:3px 9px;border-radius:6px;background:var(--card);border:1px solid var(--line);color:#54514a;}
    .scene{font-size:.86rem;color:#54514a;line-height:1.5;margin-top:6px;min-height:1.2em;}
    /* YOLO 框 → LLM 结构化档案 */
    #subjects{margin-top:10px;}
    .subjhead{font-size:.7rem;letter-spacing:.6px;color:var(--muted);text-transform:uppercase;margin-bottom:6px;}
    .subj{background:var(--card);border:1px solid var(--line);border-left:2px solid var(--accent);
      border-radius:8px;padding:8px 10px;margin-bottom:6px;}
    .subj .subjline{display:flex;justify-content:space-between;align-items:center;font-size:.82rem;}
    .subj .subjline b{color:var(--fg);}
    .subj .box{font-family:var(--mono);font-size:.68rem;color:var(--muted);}
    .subj .subjapp{font-size:.8rem;color:#54514a;margin-top:3px;line-height:1.4;}
    .subj .atags{display:flex;flex-wrap:wrap;gap:5px;margin-top:5px;}
    .subj .atag{font-size:.68rem;padding:2px 7px;border-radius:5px;background:rgba(204,120,92,.12);
      border:1px solid rgba(204,120,92,.35);color:var(--accent2);}

    /* 日志 */
    .log{max-height:300px;overflow:auto;margin-top:4px;}
    .logrow{display:flex;gap:10px;padding:8px 6px;border-bottom:1px solid var(--line);font-size:.8rem;align-items:flex-start;
      cursor:pointer;border-radius:6px;}
    .logrow:hover{background:var(--card);}
    .logrow .t{color:var(--muted);font-family:var(--mono);font-variant-numeric:tabular-nums;white-space:nowrap;}
    .logrow .dot{width:8px;height:8px;border-radius:50%;margin-top:5px;flex:none;background:var(--idle);}
    .logrow.normal .dot{background:#a39e8e;}
    .logrow.attention .dot{background:var(--warn);}
    .logrow.alert .dot{background:var(--alert);}
    .logrow .msg{flex:1;}
    .logrow .mtag{font-size:.68rem;color:var(--ok);font-weight:700;}
    .logrow .thumb{width:42px;height:30px;object-fit:cover;border-radius:4px;border:1px solid var(--line);flex:none;}
    .logrow .arrow{color:var(--muted);font-size:.7rem;align-self:center;}
    .footer{color:#a39e8e;font-size:.72rem;text-align:center;padding:8px 0 18px;}
    a{color:var(--accent2);}

    /* 顶栏：标题 + 模式切换器 */
    .topbar-main{display:flex;justify-content:space-between;align-items:center;
      padding:18px 24px;background:var(--bg);border-bottom:1px solid var(--line);}
    .topbar-title h2{font-size:1.3rem;color:var(--fg);margin:0;}
    .mode-switcher{display:flex;gap:8px;}
    .mode-btn{padding:8px 16px;border:1px solid var(--line);border-radius:8px;
      background:var(--card);color:var(--muted);font-size:.88rem;font-weight:600;cursor:pointer;transition:.18s;}
    .mode-btn:hover{border-color:var(--accent);color:var(--fg);}
    .mode-btn.active{background:var(--accent);color:#fff;border-color:var(--accent);box-shadow:0 2px 8px rgba(204,120,92,.3);}

    /* 视图容器 */
    .view-container{min-height:calc(100vh - 80px);}

    /* ===== 仪表盘布局（监控模式）===== */
    .dashboard-layout{display:grid;grid-template-columns:300px 1fr 360px;gap:20px;padding:20px;
      height:calc(100vh - 120px);overflow:hidden;}
    
    /* 左侧配置面板 */
    .dash-sidebar{overflow-y:auto;display:flex;flex-direction:column;gap:16px;padding-right:8px;}
    .dash-section{background:var(--card);border:1px solid var(--line);border-radius:12px;padding:16px;}
    .dash-heading{font-size:.95rem;font-weight:700;color:var(--fg);margin:0 0 12px 0;}
    .dash-controls{display:flex;flex-direction:column;gap:10px;}
    .dash-btn{width:100%;padding:8px 12px;border:1px solid var(--line);border-radius:8px;
      background:var(--bg);color:var(--fg);font-size:.85rem;cursor:pointer;transition:.18s;}
    .dash-btn:hover{border-color:var(--accent);background:var(--card);}
    .dash-select{width:100%;padding:8px 12px;border:1px solid var(--line);border-radius:8px;
      background:var(--bg);color:var(--fg);font-size:.85rem;}
    .dash-input{width:100%;padding:8px 12px;border:1px solid var(--line);border-radius:8px;
      background:var(--bg);color:var(--fg);font-size:.85rem;}
    .dash-input-group{display:flex;flex-direction:column;gap:6px;}
    .dash-label{font-size:.8rem;color:var(--muted);font-weight:600;}
    .dash-hint{font-size:.78rem;color:var(--muted);}
    .dash-switch{display:flex;align-items:center;gap:10px;cursor:pointer;}
    .dash-switch input[type="checkbox"]{display:none;}
    .dash-switch-slider{width:40px;height:22px;background:var(--idle);border-radius:11px;position:relative;transition:.2s;}
    .dash-switch-slider::after{content:"";position:absolute;width:16px;height:16px;border-radius:50%;
      background:#fff;top:3px;left:3px;transition:.2s;}
    .dash-switch input:checked + .dash-switch-slider{background:var(--ok);}
    .dash-switch input:checked + .dash-switch-slider::after{left:21px;}
    .dash-switch-label{font-size:.85rem;color:var(--fg);flex:1;}
    .dash-modes{display:flex;flex-direction:column;gap:6px;}
    .dash-radio{display:flex;align-items:center;gap:8px;font-size:.82rem;color:var(--fg);padding:6px 8px;
      background:var(--bg);border:1px solid var(--line);border-radius:6px;cursor:pointer;}
    .dash-radio input{accent-color:var(--accent);}
    
    /* 主视图区域 */
    .dash-main{display:flex;flex-direction:column;gap:16px;overflow:hidden;}
    .dash-toolbar{display:flex;gap:12px;flex-wrap:wrap;}
    .dash-btn-primary{padding:10px 20px;border:none;border-radius:8px;background:var(--accent);
      color:#fff;font-size:.9rem;font-weight:600;cursor:pointer;transition:.18s;box-shadow:0 2px 6px rgba(204,120,92,.25);}
    .dash-btn-primary:hover{box-shadow:0 4px 12px rgba(204,120,92,.35);transform:translateY(-1px);}
    .dash-btn-primary:disabled{background:var(--idle);cursor:not-allowed;opacity:.5;}
    .dash-btn-danger{padding:10px 20px;border:1px solid var(--alert);border-radius:8px;
      background:var(--alert);color:#fff;font-size:.9rem;font-weight:600;cursor:pointer;transition:.18s;}
    .dash-btn-danger:disabled{background:var(--idle);border-color:var(--idle);cursor:not-allowed;opacity:.5;}
    .dash-btn-secondary{padding:10px 20px;border:1px solid var(--line);border-radius:8px;
      background:var(--card);color:var(--fg);font-size:.9rem;font-weight:600;cursor:pointer;transition:.18s;}
    .dash-btn-secondary:hover{border-color:var(--accent);}
    .dash-btn-secondary:disabled{opacity:.5;cursor:not-allowed;}
    
    /* 视频画面 - 4:3 比例（传统监控摄像头比例，更节省横向空间） */
    .dash-video-container{flex:0 0 auto;aspect-ratio:4/3;max-height:480px;width:100%;
      background:var(--card);border:1px solid var(--line);border-radius:12px;overflow:hidden;}
    .dash-stage{position:relative;width:100%;height:100%;background:#1a1916;}
    .dash-stage video{width:100%;height:100%;object-fit:contain;display:none;}
    .dash-stage video.on{display:block;}
    .scan-dash{position:absolute;top:0;left:0;right:0;height:3px;background:linear-gradient(90deg,transparent,var(--accent),transparent);
      opacity:0;}
    .dash-stage.analyzing .scan-dash{opacity:.6;animation:scan 2s ease-in-out infinite;}
    @keyframes scan{0%,100%{top:0;opacity:0}50%{top:50%;opacity:.6}}
    @keyframes pulsecorner{0%,100%{opacity:.7}50%{opacity:.3}}
    .boxes-dash{position:absolute;inset:0;pointer-events:none;}
    .hud-dash{position:absolute;top:14px;right:14px;background:rgba(26,25,22,.82);backdrop-filter:blur(6px);
      border-radius:8px;padding:8px 12px;color:var(--accent);font-size:.78rem;font-family:var(--mono);
      font-variant-numeric:tabular-nums;display:none;}
    .dash-stage.analyzing .hud-dash{display:block;}
    .corner-dash{position:absolute;top:14px;left:14px;font-size:.78rem;color:var(--accent);
      font-family:var(--mono);font-variant-numeric:tabular-nums;display:none;}
    .dash-stage.analyzing .corner-dash{display:block;}
    .empty-dash{position:absolute;inset:0;display:grid;place-items:center;text-align:center;
      color:var(--muted);font-size:.95rem;pointer-events:none;}
    #video.on ~ .empty-dash{display:none;}
    
    /* 画面理解 - 固定在视频下方，永远可见 */
    .dash-understanding{background:var(--card);border:1px solid var(--line);border-radius:12px;padding:14px;
      flex:0 0 auto;}
    .dash-understanding-title{font-size:.88rem;font-weight:700;color:var(--muted);margin-bottom:10px;}
    .dash-scene{font-size:.9rem;color:var(--fg);line-height:1.5;margin-bottom:8px;}
    .dash-tags{display:flex;flex-wrap:wrap;gap:6px;}
    .dash-tag{padding:4px 10px;border-radius:6px;background:var(--bg);border:1px solid var(--line);
      font-size:.75rem;color:var(--fg);}
    
    /* 目标档案 - 在监控模式也显示 */
    #dash-subjects .subjhead{font-size:.7rem;letter-spacing:.6px;color:var(--muted);text-transform:uppercase;margin:10px 0 6px 0;}
    #dash-subjects .subj{background:var(--bg);border:1px solid var(--line);border-left:2px solid var(--accent);
      border-radius:8px;padding:8px 10px;margin-bottom:6px;}
    #dash-subjects .subj .subjline{display:flex;justify-content:space-between;align-items:center;font-size:.82rem;}
    #dash-subjects .subj .subjline b{color:var(--fg);}
    #dash-subjects .subj .box{font-family:var(--mono);font-size:.68rem;color:var(--muted);}
    #dash-subjects .subj .subjapp{font-size:.8rem;color:var(--fg);margin-top:3px;line-height:1.4;}
    #dash-subjects .subj .atags{display:flex;flex-wrap:wrap;gap:5px;margin-top:5px;}
    #dash-subjects .subj .atag{font-size:.68rem;padding:2px 7px;border-radius:5px;background:rgba(204,120,92,.12);
      border:1px solid rgba(204,120,92,.35);color:var(--accent2);}
    
    /* 比对匹配结果（可选显示） */
    .dash-match{background:var(--card);border:2px solid var(--ok);border-radius:12px;padding:14px;
      display:flex;align-items:center;gap:14px;flex:0 0 auto;box-shadow:0 2px 10px rgba(42,144,103,.12);}
    .dash-match-icon{font-size:1.8rem;}
    .dash-match-content{flex:1;}
    .dash-match-label{font-size:.75rem;color:var(--muted);font-weight:600;}
    .dash-match-value{font-size:1.2rem;font-weight:700;color:var(--fg);margin:2px 0;}
    .dash-match-reason{font-size:.8rem;color:var(--muted);}
    
    /* 右侧面板：统计 + 日志 */
    .dash-right-panel{display:flex;flex-direction:column;gap:16px;overflow:hidden;}
    
    /* 统计数据紧凑版 */
    .dash-stats-compact{display:grid;grid-template-columns:repeat(5,1fr);gap:8px;padding:12px;
      background:var(--card);border:1px solid var(--line);border-radius:12px;}
    .dash-stat-mini{display:flex;flex-direction:column;align-items:center;gap:4px;}
    .dash-stat-mini-label{font-size:.72rem;color:var(--muted);text-align:center;}
    .dash-stat-mini-value{font-size:1.1rem;font-weight:700;color:var(--fg);font-family:var(--mono);
      font-variant-numeric:tabular-nums;}
    
    /* 事件日志 */
    .dash-log-section{flex:1;display:flex;flex-direction:column;background:var(--card);border:1px solid var(--line);
      border-radius:12px;padding:16px;overflow:hidden;}
    .dash-log-container{flex:1;overflow-y:auto;display:flex;flex-direction:column;gap:10px;padding-right:6px;}
    .dash-log-empty{text-align:center;color:var(--muted);font-size:.85rem;margin-top:40px;}
    .dash-log-item{display:flex;gap:10px;padding:10px;background:var(--bg);border:1px solid var(--line);
      border-radius:8px;font-size:.82rem;}
    .dash-log-item .dot{width:8px;height:8px;border-radius:50%;margin-top:5px;flex:none;background:var(--idle);}
    .dash-log-item.normal .dot{background:#a39e8e;}
    .dash-log-item.attention .dot{background:var(--warn);}
    .dash-log-item.alert .dot{background:var(--alert);}
    .dash-log-item .content{flex:1;display:flex;flex-direction:column;gap:4px;}
    .dash-log-item .time{color:var(--muted);font-family:var(--mono);font-size:.75rem;font-variant-numeric:tabular-nums;}
    .dash-log-item .msg{color:var(--fg);line-height:1.4;}

    /* 比对标准单选 */
    .modes{display:flex;flex-direction:column;gap:6px;margin-top:6px;}
    .mode{display:flex;align-items:center;gap:8px;font-size:.84rem;color:#54514a;
      background:var(--card);border:1px solid var(--line);border-radius:8px;padding:7px 10px;cursor:pointer;}
    .mode input{accent-color:var(--accent);}
    .compareState.on{color:var(--ok);}

    /* 帧预览弹窗 */
    .modal{position:fixed;inset:0;background:rgba(58,54,46,.42);backdrop-filter:blur(3px);
      display:none;place-items:center;z-index:50;padding:20px;}
    .modal.open{display:grid;}
    #modal{z-index:60;}
    .modalbox{background:var(--panel);border:1px solid var(--line);border-radius:14px;
      max-width:760px;width:100%;max-height:88vh;overflow:auto;padding:16px;box-shadow:var(--shadow-lg);}
    .modalbox h3{margin:0 0 4px;font-size:1rem;}
    .modalbox .mt{color:var(--muted);font-size:.78rem;margin-bottom:10px;}
    .modalbox img.frame{width:100%;border-radius:10px;border:1px solid var(--line);background:var(--stage);}
    .modalbox pre{background:#f3f1ea;border:1px solid var(--line);border-radius:8px;padding:12px;
      font-family:var(--mono);font-size:.78rem;overflow:auto;max-height:280px;margin-top:12px;color:#44423b;}
    .modalbox .close{float:right;}

    /* 历史周期列表 */
    .hsess{display:flex;align-items:center;gap:12px;padding:11px 12px;margin-top:8px;
      background:var(--card);border:1px solid var(--line);border-radius:8px;cursor:pointer;transition:.15s;}
    .hsess:hover{border-color:var(--accent);background:#f6efe9;}
    .hsess .hid{font-weight:600;color:var(--accent2);font-family:var(--mono);font-size:.8rem;}
    .hsess .hmeta{flex:1;font-size:.78rem;color:var(--muted);}
    .hsess .hnum{font-size:.74rem;color:var(--fg);white-space:nowrap;}
    .hsess .hnum b{color:var(--accent2);}
    .hsess .hnum .ha{color:var(--alert);}
    .hsess .hdel{color:var(--alert);border-color:rgba(192,57,43,.35);background:transparent;padding:5px 9px;font-size:.7rem;box-shadow:none;}
    .hempty{color:var(--muted);padding:16px 4px;font-size:.84rem;}

    /* ===== 交互式流水线画布：架构图即控制台（浅色 / 流动连线 / 可插拔模型） ===== */
    .canvas{max-width:1800px;margin:12px auto 0;padding:0 24px;}
    .canvas .ctitle{display:flex;align-items:baseline;gap:12px;margin:0 2px 4px;flex-wrap:wrap;}
    .canvas .ctitle h2{margin:0;font-size:1.02rem;font-family:var(--serif);font-weight:600;color:var(--fg);letter-spacing:.1px;text-transform:none;}
    .canvas .ctitle .hint{margin:0;}
    .railwrap{background:none;border:none;border-radius:0;padding:16px 2px 0;margin-top:10px;box-shadow:none;overflow-x:auto;}
    .railwrap::-webkit-scrollbar{height:9px;}
    .railwrap::-webkit-scrollbar-thumb{background:#dcd7c9;border-radius:5px;}
    .railwrap::-webkit-scrollbar-track{background:transparent;}
    .rail{display:flex;align-items:stretch;gap:0;min-width:max-content;}

    .pnode{position:relative;width:212px;flex:none;background:#fff;border:1px solid var(--line);
      border-radius:14px;padding:13px 14px 14px;transition:transform .18s,box-shadow .18s,border-color .18s;
      box-shadow:0 1px 2px rgba(50,46,38,.04);display:flex;flex-direction:column;}
    .pnode.wide{width:248px;}
    .pnode.active{border-color:var(--accent);transform:translateY(-2px);
      box-shadow:0 0 0 1px var(--accent),0 10px 26px rgba(204,120,92,.20);}
    .pnode.hit{border-color:var(--ok);box-shadow:0 0 0 1px var(--ok),0 8px 22px rgba(42,144,103,.16);}
    .pnode.warn{border-color:var(--warn);}
    .pnode .ph{display:flex;align-items:center;gap:9px;font-weight:600;font-size:.86rem;color:var(--fg);}
    .pnode .pico{width:28px;height:28px;border-radius:8px;display:grid;place-items:center;
      background:var(--card);border:1px solid var(--line);font-size:15px;flex:none;transition:.18s;}
    .pnode.active .pico{background:linear-gradient(135deg,var(--accent),var(--accent2));border-color:transparent;box-shadow:0 3px 10px rgba(204,120,92,.4);}
    .pnode.hit .pico{background:linear-gradient(135deg,var(--ok),#1f7d59);border-color:transparent;}
    .pnode .pname{flex:1;}
    .pnode .pled{width:8px;height:8px;border-radius:50%;background:var(--idle);transition:.2s;flex:none;}
    .pnode.on .pled{background:var(--ok);}
    .pnode.active .pled{background:var(--accent);animation:pulse 1.2s infinite;}
    .pnode .pbody{margin-top:11px;display:flex;flex-direction:column;gap:9px;}
    .pnode .pst{font-size:.71rem;color:var(--muted);margin-top:11px;padding-top:9px;border-top:1px dashed var(--line);
      min-height:1.4em;line-height:1.35;font-family:var(--mono);font-variant-numeric:tabular-nums;word-break:break-word;}
    .pnode .pstep{position:absolute;top:-9px;left:13px;width:20px;height:20px;border-radius:50%;
      background:#fff;border:1px solid var(--line);display:grid;place-items:center;font-size:.66rem;font-weight:700;color:var(--muted);z-index:10;}
    .pnode.active .pstep,.pnode.hit .pstep{border-color:var(--accent);color:var(--accent);}

    /* 节点内联控件 */
    .psel{width:100%;font-size:.77rem;padding:7px 26px 7px 10px;border-radius:8px;}
    .plabel{font-size:.68rem;color:var(--muted);letter-spacing:.2px;margin-bottom:-3px;}
    .pswitch{display:flex;align-items:center;gap:9px;font-size:.76rem;color:#56524a;cursor:pointer;user-select:none;}
    .pswitch b{color:var(--fg);font-weight:600;}
    .tgl{position:relative;width:34px;height:19px;flex:none;display:inline-block;}
    .tgl input{opacity:0;width:0;height:0;position:absolute;margin:0;}
    .tgl .sl{position:absolute;inset:0;background:var(--idle);border-radius:999px;transition:.18s;}
    .tgl .sl::before{content:"";position:absolute;left:2px;top:2px;width:15px;height:15px;border-radius:50%;
      background:#fff;transition:.18s;box-shadow:0 1px 2px rgba(50,46,38,.25);}
    .tgl input:checked + .sl{background:var(--accent);}
    .tgl input:checked + .sl::before{transform:translateX(15px);}
    .pinline{display:flex;align-items:center;gap:7px;}
    .pinline input[type=number]{padding:6px 8px;text-align:center;}
    .pinline .u{font-size:.72rem;color:var(--muted);white-space:nowrap;}
    .pmini{font-size:.72rem;padding:6px 10px;}
    .pnode .modes{display:flex;flex-direction:row;flex-wrap:wrap;gap:6px;}
    .pnode .mode{padding:5px 8px;font-size:.74rem;flex:1 1 auto;text-align:center;}
    .pnode .ref{margin-top:0;}
    .pnode .ref img{width:38px;height:38px;}
    .rail-input-mini{width:100%;aspect-ratio:16/9;border-radius:9px;border:1px solid var(--line);
      background:var(--stage);object-fit:contain;display:block;}
    .planbox{font-size:.7rem;color:var(--muted);line-height:1.35;background:var(--card);
      border:1px solid var(--line);border-radius:8px;padding:7px 9px;}
    .modelpill{font-size:.64rem;color:var(--accent2);background:rgba(204,120,92,.1);
      border:1px solid rgba(204,120,92,.3);border-radius:999px;padding:1px 7px;margin-left:auto;font-weight:600;}

    /* ===== 架构图（紧凑·全屏免滚动）：栏A 输入+检测+门控 / 栏B 编译+巡航+理解 / ⑦结果 ＋ ⑧日志(并排,日志窄) ===== */
    .diagram{display:flex;align-items:stretch;justify-content:center;gap:0;min-width:max-content;}
    .dcol{display:flex;flex-direction:column;}
    .colA{flex:0 0 470px;}                 /* 输入栏加宽：监控画面更大 */
    .colB{flex:0 0 280px;}
    .cres{flex:0 0 360px;}                 /* ⑦ 结果 */
    .clog{flex:0 0 220px;}                 /* ⑧ 日志：窄栏 */
    .dcol .pnode{width:100%;}
    /* 每栏长度一致 + 单个模块超长内滚动 */
    .colA,.colB{min-height:0;}
    .dcol > .pnode{flex:0 0 auto;display:flex;flex-direction:column;}
    .dcol > .pnode .pbody{flex:1;overflow-y:auto;min-height:0;}
    .colA > .pnode:last-child,.colB > .pnode:last-child{flex:1 1 auto;}  /* 末节点撑满对齐底边 */
    .dcol .pnode.wide{width:100%;}
    /* 紧凑节点：缩小内边距与间距，压低整体高度 */
    .pnode{padding:11px 13px 11px;}
    .pnode .pbody{margin-top:9px;gap:8px;}
    .pnode .pst{margin-top:9px;padding-top:8px;}
    /* 输入视频：用上左右富余空间适当调大 */
    .din .dctrl{margin-top:9px;}
    .din .stage{flex:0 0 auto;height:236px;min-height:0;margin-top:9px;}
    /* 栏内竖向连线固定小高度 */
    .conn-v{flex:0 0 18px;min-height:18px;}
    /* ⑦⑧ 内容设最大高度，超长则各自内部上下滚动；空内容时也撑满与各栏对齐 */
    .cres,.clog{align-self:stretch;}
    .cres .pbody{flex:1;max-height:none;overflow-y:auto;padding-right:2px;}
    .clog{display:flex;flex-direction:column;}
    .clog .log{flex:1;height:auto;max-height:none;min-height:120px;overflow-y:auto;margin-top:6px;}
    /* ⑦ 结果栏整体缩字；⑧ 日志窄栏缩字 */
    .cres .ph .pname,.clog .ph .pname{font-size:.8rem;}
    .cres .matchcard{padding:11px;}
    .cres .matchcard .big{font-size:1.15rem;}
    .cres .matchcard .conf{font-size:.72rem;}
    .cres .matchcard .reason{font-size:.76rem;}
    .cres .stat .n{font-size:1.04rem;}
    .cres .stat .l{font-size:.62rem;}
    .cres .scene{font-size:.74rem;}
    .clog .log{font-size:.72rem;}
    @media(max-width:1100px){
      .diagram{flex-direction:column;min-width:0;justify-content:flex-start;align-items:stretch;}
      .colA,.colB,.cres,.clog{flex:1 1 auto;width:100%;}
      .din .stage{height:240px;}
      .conn-h,.conn-h.cross{display:none;}
      .cres .pbody{max-height:none;overflow:visible;}
      .clog .log{max-height:240px;}
    }

    /* 流动连接线（CSS 渐变，常态轻流动，活跃时加亮加速） */
    .conn-h{flex:0 0 50px;align-self:center;position:relative;height:20px;}
    .conn-h::before{content:"";position:absolute;left:5px;right:11px;top:50%;height:2px;transform:translateY(-50%);
      background:repeating-linear-gradient(to right,var(--accent) 0 3px,transparent 3px 11px);
      background-size:14px 2px;opacity:.22;animation:flowright 1.6s linear infinite;}
    .conn-h.flow::before{opacity:1;animation-duration:.5s;}
    .conn-h::after{content:"";position:absolute;right:3px;top:50%;transform:translateY(-50%);
      border-left:7px solid var(--idle);border-top:5px solid transparent;border-bottom:5px solid transparent;transition:.18s;}
    .conn-h.flow::after{border-left-color:var(--accent);}
    @keyframes flowright{to{background-position:14px 0;}}

    /* 跨栏连线：Z 形（横出→竖升→横进），直角转折 */
    .conn-h.cross{flex:0 0 50px;align-self:stretch;height:auto;position:relative;}
    .conn-h.cross svg{position:absolute;left:0;top:0;width:100%;height:100%;overflow:visible;}
    .conn-h.cross path{fill:none;stroke:var(--idle);stroke-width:2.5;opacity:.3;
      stroke-dasharray:8 6;animation:flowpath 2s linear infinite;stroke-linecap:square;}
    .conn-h.cross.flow path{stroke:var(--accent);opacity:1;stroke-width:3;animation-duration:.7s;}
    .conn-h.cross .arrow{fill:var(--idle);transition:.18s;}
    .conn-h.cross.flow .arrow{fill:var(--accent);}
    @keyframes flowpath{to{stroke-dashoffset:-14;}}
    .conn-h.cross.flow::after{border-bottom-color:var(--accent);}
    @keyframes flowup{to{background-position:0 -14px;}}
    .conn-v{flex:0 0 18px;min-height:18px;position:relative;width:100%;}
    .conn-v::before{content:"";position:absolute;top:3px;bottom:9px;left:50%;width:2px;transform:translateX(-50%);
      background:repeating-linear-gradient(to bottom,var(--accent) 0 3px,transparent 3px 11px);
      background-size:2px 14px;opacity:.22;animation:flowdown 1.6s linear infinite;}
    .conn-v.flow::before{opacity:1;animation-duration:.5s;}
    .conn-v::after{content:"";position:absolute;bottom:1px;left:50%;transform:translateX(-50%);
      border-top:7px solid var(--idle);border-left:5px solid transparent;border-right:5px solid transparent;transition:.18s;}
    .conn-v.flow::after{border-top-color:var(--accent);}
    @keyframes flowdown{to{background-position:0 14px;}}
  </style>
</head>
<body>
  <div class="topbar">
    <div class="brand"><span class="logo">◉</span> 实时比对监控系统 <span style="color:var(--muted);font-weight:400;font-size:.78rem">实时视频分析</span></div>
    <div class="live"><span class="led" id="led"></span><span id="liveText">待机</span></div>
