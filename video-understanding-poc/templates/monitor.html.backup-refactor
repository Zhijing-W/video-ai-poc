    function stopMonitor(){
      const wasRunning = timer !== null;
      if (timer) { clearInterval(timer); timer = null; }
      stage.classList.remove("analyzing");
      const stageDash = $("stage-dash");
      if (stageDash) stageDash.classList.remove("analyzing");
      clearBoxes();
      $("led").classList.remove("on"); $("liveText").textContent = "已停止";
      dimPath();
      nstat("yolo", "待机"); nstat("gate", "—");
      nstat("cruise", activeCompare ? "已暂停" : "未启用");
      if (wasRunning) startCooldown();   // 进入 5s 冷静期，收尾后再归档
      else { nstat("result", "已停止"); clearStartStop(false); }
    }

    // 结束监控后 5s 冷静期：继续收录延迟到达的帧，期满才归档；期间不允许开始新监控
    function startCooldown(){
      const SEC = 5;
      let left = SEC;
      const tickDown = () => {
        $("liveText").textContent = "● 冷静期 " + left + "s";
        nstat("result", "冷静期 " + left + "s · 收尾中（延迟帧仍在收录）");
      };
      tickDown();
      $("led").classList.add("cooldown");
      clearStartStop(true);              // 冷静期内禁开始（btnStop 也已禁用）
      $("btnStop").disabled = true;
      logRow("normal", "监控已停止，进入 " + SEC + "s 冷静期：继续收录延迟到达的帧，期满后归档（这 " + SEC + "s 内不可开始新监控）", false, null);
      cooldownTimer = setInterval(() => {
        left--;
        if (left > 0) { tickDown(); return; }
        clearInterval(cooldownTimer); cooldownTimer = null;
        $("led").classList.remove("cooldown");
        $("liveText").textContent = "已停止"; nstat("result", "已停止");
        saveCycle();                     // 收尾完成，归档（含冷静期内补到的帧）
        clearStartStop(false);           // 恢复可开始
      }, 1000);
    }

    // 保存当前监控周期到后端（历史日志）
    async function saveCycle(){
      if (!cycle || !cycle.entries.length) { cycle = null; return; }
      const payload = {
        started_at: cycle.startedAt,
        ended_at: new Date().toISOString(),
        target: activeCompare ? (activeCompare.target || "（参考图）") : null,
        mode: activeCompare ? activeCompare.mode : null,
        stats: { frames: stats.frames, match: stats.match, alert: stats.alert },
        entries: cycle.entries.slice(-300),   // 上限 300 帧，控制体积
      };
      cycle = null;
      try {
        const r = await fetch("/monitor-sessions", {
          method:"POST", headers:{"Content-Type":"application/json"}, body: JSON.stringify(payload)
        });
        if (r.ok) { const d = await r.json(); logRow("normal", "已归档监控周期 " + d.id + "（" + d.frames + " 帧），可在『历史日志』查看", false, null); }
      } catch(e) { /* 离线保存失败忽略 */ }
    }
    function stopCamera(){ if (stream){ stream.getTracks().forEach(t=>t.stop()); stream=null; } video.srcObject=null; camOn=false; setCamBtn(false); clearBoxes(); }
    function stopAll(){ stopMonitor(); stopCamera(); }
    $("boxToggle").onchange = () => { if (!$("boxToggle").checked) clearBoxes(); };
    
    // 采样间隔修改时，如果正在监控，则重启定时器
    function restartTimerIfRunning() {
      if (timer) {
        clearInterval(timer);
        timer = setInterval(tick, intervalMs());
        logRow("normal", "⚙ 采样间隔已更新为 " + ($("intervalVal").value) + ($("intervalUnit").value === "1000" ? "秒" : $("intervalUnit").value === "60000" ? "分钟" : "毫秒"), false, null);
      }
    }
    $("intervalVal").oninput = restartTimerIfRunning;
    $("intervalUnit").onchange = restartTimerIfRunning;
    
    window.addEventListener("resize", clearBoxes);

    // —— 抓帧 → 后端分析 ——
    async function tick(){
      if (inFlight) return;                       // 上一帧没返回则跳过（天然门控，防堆积）
      if (!video.videoWidth) return;
      const W = 640, H = Math.round(video.videoHeight / video.videoWidth * W);
      canvas.width = W; canvas.height = H;
      canvas.getContext("2d").drawImage(video, 0, 0, W, H);
      const dataUri = canvas.toDataURL("image/jpeg", 0.7);
      updateMini(dataUri);   // 架构图「输入源」节点的实时小预览

      // 级联：目标可被 YOLO 独立判断且开启巡航 → 走 YOLO 巡航 + 定期 gpt-4o 审计
      const plan = activeCompare && activeCompare.plan;
      const cruiseOn = plan && plan.can_yolo_handle && $("cruiseToggle").checked;

      inFlight = true; 
      stage.classList.add("analyzing");
      const stageDash = $("stage-dash");
      if (stageDash) stageDash.classList.add("analyzing");
      try {
        if (cruiseOn) {
          cruiseCount++;
          // #2 颜色/事件触发审计：目标在场时，裁决翻转或到达审计间隔才花 gpt-4o；
          // 目标不在场则巡航足以确定「未命中」，仅用 4× 间隔做长心跳安全网，省下大量审计调用。
          const tcls = plan.yolo_class;
          const targetSeen = !!(lastCounts && tcls && lastCounts[tcls] > 0);
          const sinceAudit = cruiseCount - lastAuditCount;
          const doAudit = targetSeen
            ? (cruiseFlip || sinceAudit >= auditEvery())
            : (sinceAudit >= auditEvery() * 4);
          if (doAudit) { lastAuditCount = cruiseCount; cruiseFlip = false; await auditTick(dataUri, plan); }
          else await cruiseTickFrame(dataUri, plan);
        } else {
          await analyzeTick(dataUri, plan);
        }
      } catch (e) { logRow("alert", "网络错误：" + e.message, false, null); }
      finally { 
        inFlight = false; 
        stage.classList.remove("analyzing"); 
        const stageDash = $("stage-dash");
        if (stageDash) stageDash.classList.remove("analyzing");
      }
    }

    // 普通路径（无巡航 / YOLO 搞不定）：YOLO→门控→条件 gpt-4o
    async function analyzeTick(dataUri, plan){
      const payload = {
        image: dataUri, target: null, reference_image: null,
        gate_enabled: $("gateToggle").checked,
        prev_counts: lastCounts,
        since_last_llm_ms: lastLlmTs ? (Date.now() - lastLlmTs) : null,
        comparing: !!activeCompare,
        plan: plan || null,
        last_llm_signature: lastLlmSig,   // #1 复用：签名未变后端会直接复用、省一次调用
        yolo_model: yoloModelSel, llm_model: llmModelSel,   // 可插拔模型（后端接入后生效）
      };
      if (activeCompare) { payload.target = activeCompare.target; payload.reference_image = activeCompare.reference; }
      const t0 = performance.now();
      const r = await fetch("/analyze-frame", {
        method: "POST", headers: {"Content-Type":"application/json"}, body: JSON.stringify(payload)
      });
      const ms = Math.round(performance.now() - t0);
      if (!r.ok) { logRow("alert", "分析失败：" + (await r.text()).slice(0,120), false, null); return; }
      const data = await r.json();
      lastCounts = (data.yolo && data.yolo.counts) || {};
      const usedLlm = data.gated && !data.reused;
      const route = ["input","yolo","gate"];
      if (activeCompare && plan) route.push("compile");
      if (usedLlm) route.push("llm");
      route.push("result");
      lightPath(route);
      nstat("gate", data.gated ? (data.reused ? "→ 复用 ♻" : "→ gpt-4o") : "跳过 ⏭");
      if (data.gated && !data.reused) {
        // 真·调了 gpt-4o：缓存权威结论 + 签名，供后续复用
        lastLlmTs = Date.now();
        lastLlmSig = data.signature || null; lastLlmData = data;
        render(data, ms, dataUri);
      } else if (data.signature && data.signature === lastLlmSig && lastLlmData) {
        // #1 复用上次权威结论（后端已省下 LLM 调用），避免显示 YOLO 空壳
        const shown = Object.assign({}, lastLlmData, { yolo: data.yolo, gated: false, reused: true, cruise_match: null });
        shown.result = Object.assign({}, lastLlmData.result || {}, {
          notification: data.reused ? "♻ 复用上次 gpt-4o 结论（签名未变，省一次调用）"
                                    : "⏭ " + (((lastLlmData.result||{}).scene) || "沿用上次结论"),
        });
        render(shown, ms, dataUri);
      } else {
        render(data, ms, dataUri);  // 门控跳过且签名不同 → 显示 YOLO 标签合成结果
      }
    }

    // 巡航帧（便宜）：只跑 /cruise-frame（YOLO+颜色），不调 gpt-4o，缓冲起来等审计
    async function cruiseTickFrame(dataUri, plan){
      const t0 = performance.now();
      const r = await fetch("/cruise-frame", {
        method:"POST", headers:{"Content-Type":"application/json"},
        body: JSON.stringify({ image: dataUri, plan, yolo_model: yoloModelSel })
      });
      const ms = Math.round(performance.now() - t0);
      if (!r.ok) { logRow("alert", "巡航失败：" + (await r.text()).slice(0,120), false, null); return; }
      const data = await r.json();
      lastCounts = (data.yolo && data.yolo.counts) || {};
      lightPath(["input","yolo","compile","cruise","result"]);
      nstat("gate", "巡航旁路 ⏭");
      const verdict = !!(data.cruise && data.cruise.is_match);
      if (lastCruiseVerdict !== null && verdict !== lastCruiseVerdict) cruiseFlip = true;  // #2 颜色裁决翻转 → 触发审计
      lastCruiseVerdict = verdict;
      const fid = renderCruise(data, ms, dataUri, plan);
      cruiseBuf.push({ fid, dataUri, verdict });
    }

    // 审计帧：调 /analyze-frame（带 plan）拿 gpt-4o 权威裁决 + 同帧 YOLO 巡航裁决对比
    async function auditTick(dataUri, plan){
      const payload = {
        image: dataUri, target: activeCompare.target, reference_image: activeCompare.reference,
        gate_enabled: false, comparing: true, plan,
        yolo_model: yoloModelSel, llm_model: llmModelSel,
      };
      const t0 = performance.now();
      const r = await fetch("/analyze-frame", {
        method:"POST", headers:{"Content-Type":"application/json"}, body: JSON.stringify(payload)
      });
      const ms = Math.round(performance.now() - t0);
      if (!r.ok) { logRow("alert", "审计失败：" + (await r.text()).slice(0,120), false, null); return; }
      const data = await r.json();
      lastCounts = (data.yolo && data.yolo.counts) || {};
      lightPath(["input","yolo","compile","cruise","llm","result"]);
      nstat("gate", "审计帧 · 强制 gpt-4o");
      lastLlmTs = Date.now();
      lastLlmSig = data.signature || null; lastLlmData = data;   // #1 审计是权威调用：刷新复用缓存
      if (data.cruise_match) { lastCruiseVerdict = !!data.cruise_match.is_match; cruiseFlip = false; }  // #2 同步裁决基线
      render(data, ms, dataUri);

      // gpt-4o（权威） vs YOLO 巡航（本帧）一致性
      const llmMatch = (data.result && data.result.match) ? data.result.match.is_match : null;
      const yoloMatch = (data.cruise_match) ? data.cruise_match.is_match : null;
      if (llmMatch !== null && yoloMatch !== null && llmMatch !== yoloMatch) {
        const n = Math.min(cruiseBuf.length, BACKFILL_MAX);
        logRow("alert", "🔎 审计发现偏差：YOLO 巡航判为「" + (yoloMatch?"命中":"未命中")
          + "」，gpt-4o 实为「" + (llmMatch?"命中":"未命中") + "」，后台回填最近 " + n + " 帧（不阻塞实时）…", false, null);
        backfillCruise(plan);   // 不 await：后台并发回填，实时抽帧继续，不再冻结
      } else if (cruiseBuf.length) {
        logRow("normal", "✓ 审计通过：YOLO 巡航与 gpt-4o 一致，继续巡航（已确认 " + cruiseBuf.length + " 帧）", false, null);
        cruiseBuf = [];
      }
    }

    // 回填：把巡航期缓冲的帧补调 gpt-4o，纠正结论与统计。
    // 关键修复：① 不阻塞实时循环（auditTick 不 await 本函数）；② 只回填最近 BACKFILL_MAX 帧，
    // 避免一次回溯 8 张、每张 ~8s 把画面冻死；③ backfilling 锁防止并发重入。
    let backfilling = false;
    async function backfillCruise(plan){
      if (backfilling) return;
      backfilling = true;
      const buf = cruiseBuf.slice(-BACKFILL_MAX); cruiseBuf = [];
      try {
        for (const item of buf){
          if (!activeCompare) break;   // 期间停止比对则中断
          try {
            const r = await fetch("/analyze-frame", {
              method:"POST", headers:{"Content-Type":"application/json"},
              body: JSON.stringify({ image: item.dataUri, target: activeCompare.target,
                reference_image: activeCompare.reference, gate_enabled: false, comparing: true, plan })
            });
            if (!r.ok) continue;
            const data = await r.json();
            const m = (data.result && data.result.match) || {};
            if (m.is_match !== item.verdict){
              // 之前按巡航算作「省下的帧」，现已补调 LLM：统计搬运
              stats.skipped = Math.max(0, stats.skipped - 1); stats.llm++;
              $("sLlm").textContent = stats.llm; $("sSaved").textContent = stats.skipped;
              $("sSavePct").textContent = stats.frames ? Math.round(stats.skipped / stats.frames * 100) + "%" : "0%";
              if (m.is_match === true && activeCompare) { stats.match++; $("sMatch").textContent = stats.match; }
              // 更新缓存帧的权威结论 + 追加纠正日志
              if (frameStore[item.fid]) frameStore[item.fid].res = data;
              logRow(m.is_match===true?"alert":"normal",
                "⟲ 回填纠正 帧#" + item.fid + "：" + (m.is_match?"实为命中「"+(m.target||"")+"」":"实为未命中") + " · " + (m.reason||""),
                m.is_match===true, item.fid, item.dataUri);
            }
          } catch(e) { /* 单帧回填失败忽略 */ }
        }
      } finally { backfilling = false; }
    }

    function render(data, ms, dataUri){
      const res = data.result || {};
      const gated = data.gated;          // true=调了 gpt-4o；false=门控跳过(只 YOLO)
      stats.frames++; 
      $("sFrames").textContent = stats.frames;
      if ($("dash-frames")) $("dash-frames").textContent = stats.frames;
      
      if (gated) stats.llm++; else stats.skipped++;
      $("sLlm").textContent = stats.llm; 
      $("sSaved").textContent = stats.skipped;
      const savePct = stats.frames ? Math.round(stats.skipped / stats.frames * 100) + "%" : "0%";
      $("sSavePct").textContent = savePct;
      if ($("dash-llm")) $("dash-llm").textContent = stats.llm;
      if ($("dash-save-pct")) $("dash-save-pct").textContent = savePct;
      
      const tag = gated ? (ms + "ms · gpt-4o") : (ms + "ms · YOLO");
      $("corner").textContent = "● REC  " + tag;
      if ($("corner-dash")) $("corner-dash").textContent = "● REC  " + tag;
      $("resChip") && ($("resChip").textContent = gated ? (res.alert_level || "normal").toUpperCase() : "YOLO");
      
      // 同步HUD
      const hudEl = $("hud");
      const hudDashEl = $("hud-dash");
      if (hudEl && hudDashEl) hudDashEl.innerHTML = hudEl.innerHTML;
      nstat("yolo", countsSummary(data.yolo));
      nstat("llm", stats.llm + " 次调用" + (data.reused ? " · 复用 ♻" : ""));
      drawBoxes(data.yolo, { plan: activeCompare && activeCompare.plan,
        matchedBoxes: data.cruise_match && data.cruise_match.matched_boxes });

      // 画面理解 - 同时更新技术模式和监控模式
      const sceneText = res.scene || "—";
      const tagsHtml = (res.detected_objects || []).map(o => `<span class="tag">${escapeHtml(o)}</span>`).join("");
      
      if ($("scene")) $("scene").textContent = sceneText;
      if ($("dash-scene")) $("dash-scene").textContent = sceneText;
      
      if ($("tags")) $("tags").innerHTML = tagsHtml;
      if ($("dash-tags")) $("dash-tags").innerHTML = tagsHtml.replace(/class="tag"/g, 'class="dash-tag"');
      
      // YOLO 框 → LLM 结构化档案（接 DB / 人脸 / 人形比对的字段）
      const subs = res.subjects || [];
      const subsHtml = subs.length ? ('<div class="subjhead">目标档案 · 基于 YOLO 框</div>' + subs.map(s => {
        const attrs = (s.attributes || []).map(a => `<span class="atag">${escapeHtml(a)}</span>`).join("");
        const box = (s.box || []).join(", ");
        return `<div class="subj"><div class="subjline"><b>${escapeHtml(s.ref||"")} ${escapeHtml(s.label||"")}</b>`
          + (box ? `<span class="box">[${box}]</span>` : "") + `</div>`
          + `<div class="subjapp">${escapeHtml(s.appearance||"")}</div>`
          + (attrs ? `<div class="atags">${attrs}</div>` : "") + `</div>`;
      }).join("")) : "";
      if ($("subjects")) $("subjects").innerHTML = subsHtml;
      if ($("dash-subjects")) $("dash-subjects").innerHTML = subsHtml;

      // 比对卡
      const m = res.match || {};
      const card = $("matchCard");
      const hasTarget = m.target && m.target.length > 0;
      const alert = (res.alert_level === "alert");
      if (!activeCompare) {
        card.className = "matchcard " + (alert ? "alert" : "nomatch");
        $("matchTarget").textContent = "未设置比对目标";
        $("matchBig").textContent = alert ? "⚠ 注意" : "监控中";
        $("matchConf").textContent = ""; $("matchReason").textContent = res.scene || "";
      } else {
        $("matchTarget").textContent = hasTarget ? ("目标：" + m.target) : "目标：参考图片";
        card.className = "matchcard " + (m.is_match === true ? "match" : alert ? "alert" : "nomatch");
        if (m.is_match === true) { 
          $("matchBig").textContent = "✓ 命中"; 
          stats.match++; 
          $("sMatch").textContent = stats.match;
          if ($("dash-match-count")) $("dash-match-count").textContent = stats.match;
        }
        else if (m.is_match === false) { $("matchBig").textContent = "✗ 未命中"; }
        else { $("matchBig").textContent = alert ? "⚠ 注意" : "监控中"; }
        $("matchConf").textContent = m.confidence ? ("置信度 " + m.confidence) : "";
        $("matchReason").textContent = m.reason || "";
      }
      
      // 同步更新监控模式的比对结果
      if ($("dash-match-big")) $("dash-match-big").textContent = $("matchBig").textContent;
      if ($("dash-match-reason")) $("dash-match-reason").textContent = $("matchReason").textContent;
      if ($("dash-match-card")) $("dash-match-card").style.display = activeCompare ? "flex" : "none";
      
      if (alert) { 
        stats.alert++; 
        $("sAlert").textContent = stats.alert;
        if ($("dash-alert")) $("dash-alert").textContent = stats.alert;
      }
      nstat("result", $("matchBig").textContent || "—");
      $("nd-result").classList.toggle("hit", m.is_match === true);
      $("nd-result").classList.toggle("warn", alert);

      // 存帧 + 日志（frameStore/历史存完整 payload：含 gated/gate_reason/yolo，便于点开复盘）
      const fid = ++frameSeq;
      frameStore[fid] = { dataUri, res: data, ts: new Date().toLocaleTimeString("zh-CN", {hour12:false}), ms };
      const lvl = res.alert_level || "normal";
      let msg = res.notification || res.scene || "已分析";
      if (!gated) msg = "⏭ " + msg;                                  // 门控跳过(仅 YOLO，未花 LLM)
      if (activeCompare && m.is_match === true) msg = "🎯 命中「" + (m.target||"参考图")+ "」· " + msg;
      // 累积到当前监控周期（用于历史日志）
      if (cycle) cycle.entries.push({
        seq: fid, ts: frameStore[fid].ts, level: lvl, msg,
        is_match: (activeCompare && m.is_match === true), image: dataUri, result: data,
      });
      logRow(lvl, msg, activeCompare && m.is_match === true, fid, dataUri);
    }

    // 巡航帧的轻量渲染：只有 YOLO+颜色裁决，未调 gpt-4o（计入"省下"）
    function renderCruise(data, ms, dataUri, plan){
      const yolo = data.yolo || {};
      const cruise = data.cruise || {};
      stats.frames++;
      $("sFrames").textContent = stats.frames;
      if ($("dash-frames")) $("dash-frames").textContent = stats.frames;
      
      stats.skipped++; 
      $("sSaved").textContent = stats.skipped;
      const savePct = stats.frames ? Math.round(stats.skipped / stats.frames * 100) + "%" : "0%";
      $("sSavePct").textContent = savePct;
      if ($("dash-save-pct")) $("dash-save-pct").textContent = savePct;
      $("corner").textContent = "● REC  " + ms + "ms · YOLO巡航";
      $("resChip") && ($("resChip").textContent = "巡航");
      nstat("yolo", countsSummary(yolo));
      nstat("cruise", cruise.is_match === true ? "命中（巡航）" : (cruise.reason ? "巡航中" : "巡航中"));
      nstat("result", cruise.is_match === true ? "✓ 命中（巡航）" : "巡航中");
      $("nd-result").classList.toggle("hit", cruise.is_match === true);
      $("nd-result").classList.remove("warn");
      drawBoxes(yolo, { plan, matchedBoxes: cruise.matched_boxes });

      const counts = yolo.counts || {};
      const labels = Object.keys(counts);
      const sceneText = cruise.reason || ("巡航中：" + labels.map(k=>k+"×"+counts[k]).join("、"));
      const tagsHtml = labels.map(o => `<span class="tag">${escapeHtml(o)}</span>`).join("");
      
      // 同时更新两个模式
      if ($("scene")) $("scene").textContent = sceneText;
      if ($("dash-scene")) $("dash-scene").textContent = sceneText;
      if ($("tags")) $("tags").innerHTML = tagsHtml;
      if ($("dash-tags")) $("dash-tags").innerHTML = tagsHtml.replace(/class="tag"/g, 'class="dash-tag"');
      if ($("subjects")) $("subjects").innerHTML = "";

      const card = $("matchCard");
      $("matchTarget").textContent = "目标：" + (activeCompare.target || "参考图片") + " · YOLO 巡航";
      if (cruise.is_match === true){
        card.className = "matchcard match"; $("matchBig").textContent = "✓ 命中（巡航）";
        stats.match++; 
        $("sMatch").textContent = stats.match;
        if ($("dash-match-count")) $("dash-match-count").textContent = stats.match;
      } else {
        card.className = "matchcard nomatch"; $("matchBig").textContent = "巡航中";
      }
      $("matchConf").textContent = ""; $("matchReason").textContent = cruise.reason || "";

      const fid = ++frameSeq;
      frameStore[fid] = { dataUri, res: data, ts: new Date().toLocaleTimeString("zh-CN", {hour12:false}), ms };
      let msg = "⏭ 巡航：" + (cruise.reason || "无目标");
      if (cruise.is_match === true) msg = "🎯 巡航命中「" + (activeCompare.target||"") + "」· " + (cruise.reason||"");
      if (cycle) cycle.entries.push({
        seq: fid, ts: frameStore[fid].ts, level: "normal", msg,
        is_match: cruise.is_match === true, image: dataUri, result: data,
      });
      logRow("normal", msg, cruise.is_match === true, fid, dataUri);
      return fid;
    }

    function logRow(level, msg, isMatch, fid, dataUri){
      const t = new Date().toLocaleTimeString("zh-CN", {hour12:false});
      const thumb = dataUri ? `<img class="thumb" src="${dataUri}" alt="frame"/>` : `<span class="dot"></span>`;
      
      // 技术模式日志
      const row = document.createElement("div");
      row.className = "logrow " + level;
      row.innerHTML = `${thumb}<span class="t">${t}</span>
        <span class="msg">${isMatch ? '<span class="mtag">命中 </span>' : ''}${escapeHtml(msg)}</span>
        ${fid ? '<span class="arrow">查看帧 ›</span>' : ''}`;
      if (fid) row.onclick = () => openFrame(fid);
      const log = $("log"); 
      if (log) {
        log.prepend(row);
        while (log.children.length > 60) log.removeChild(log.lastChild);
      }
      
      // 监控模式日志（带缩略图）
      const dashLogContainer = $("dash-log-container");
      if (dashLogContainer) {
        // 移除占位的empty提示
        const emptyEl = dashLogContainer.querySelector(".dash-log-empty");
        if (emptyEl) emptyEl.remove();
        
        const dashRow = document.createElement("div");
        dashRow.className = "dash-log-item " + level;
        
        // 如果有图片，添加缩略图
        const thumbHtml = dataUri ? `<img class="thumb" src="${dataUri}" alt="frame" style="width:42px;height:30px;object-fit:cover;border-radius:4px;border:1px solid var(--line);margin-right:4px;"/>` : '';
        
        dashRow.innerHTML = `<span class="dot"></span>
          <div class="content">
            <div class="time">${t}</div>
            <div class="msg" style="display:flex;align-items:center;gap:6px;">
              ${thumbHtml}
              <span>${isMatch ? '<span style="color:var(--ok);font-weight:700;font-size:.75rem">✓ 命中</span> ' : ''}${escapeHtml(msg)}</span>
            </div>
          </div>`;
        if (fid) {
          dashRow.style.cursor = "pointer";
          dashRow.onclick = () => openFrame(fid);
        }
        dashLogContainer.prepend(dashRow);
        while (dashLogContainer.children.length > 60) dashLogContainer.removeChild(dashLogContainer.lastChild);
      }
    }

    // —— 点击日志：预览发给大模型的帧 ——
    function openFrame(fid){
      const f = frameStore[fid]; if (!f) return;
      const gated = f.res && f.res.gated;
      const isCruise = f.res && f.res.cruise !== undefined && f.res.gated === undefined;
      $("modalImg").src = f.dataUri;
      $("modalTime").textContent = "采集时间 " + f.ts + " · 耗时 " + f.ms + "ms · "
        + (gated ? "已调用 gpt-4o 分析" : isCruise ? "YOLO 自动巡航（未花 LLM）" : "门控跳过 · 仅 YOLO（未花 LLM）");
      $("modalJson").textContent = JSON.stringify(f.res, null, 2);
      $("modal").classList.add("open");
    }
    $("modalClose").onclick = () => $("modal").classList.remove("open");
    $("modal").onclick = (e) => { if (e.target === $("modal")) $("modal").classList.remove("open"); };

    // —— 历史日志（按监控周期）——
    $("btnHistory").onclick = openHistory;
    $("histClose").onclick = () => $("histModal").classList.remove("open");
    $("histModal").onclick = (e) => { if (e.target === $("histModal")) $("histModal").classList.remove("open"); };
    $("histBack").onclick = () => { $("histDetail").style.display="none"; $("histList").style.display="block"; };

    async function openHistory(){
      $("histDetail").style.display="none"; $("histList").style.display="block";
      $("histList").innerHTML = '<div class="hempty">加载中…</div>';
      $("histModal").classList.add("open");
      try {
        const r = await fetch("/monitor-sessions");
        const items = (await r.json()).sessions || [];
        if (!items.length) { $("histList").innerHTML = '<div class="hempty">暂无历史周期。完整地「开始监控 → 停止监控」一次后会自动归档。</div>'; return; }
        $("histList").innerHTML = items.map(s => `
          <div class="hsess" data-id="${s.id}">
            <span class="hid">${s.id}</span>
            <span class="hmeta">${fmtSpan(s.started_at,s.ended_at)}${s.target ? ' · 目标:'+escapeHtml(s.target) : ' · 仅理解'}</span>
            <span class="hnum"><b>${s.frames||0}</b> 帧 · 命中 <b>${s.match||0}</b> · <span class="ha">告警 ${s.alert||0}</span></span>
            <button class="hdel" data-del="${s.id}">删</button>
          </div>`).join("");
        $("histList").querySelectorAll(".hsess").forEach(el => {
          el.onclick = (e) => { if (e.target.dataset.del) return; loadSession(el.dataset.id); };
        });
        $("histList").querySelectorAll("[data-del]").forEach(b => {
          b.onclick = async (e) => { e.stopPropagation();
            if (!confirm("删除该监控周期？")) return;
            await fetch("/monitor-sessions/"+b.dataset.del, {method:"DELETE"}); openHistory(); };
        });
      } catch(e) { $("histList").innerHTML = '<div class="hempty">加载失败：'+escapeHtml(e.message)+'</div>'; }
    }

    async function loadSession(id){
      try {
        const m = await (await fetch("/monitor-sessions/"+id)).json();
        $("histList").style.display="none"; $("histDetail").style.display="block";
        const st = m.stats || {};
        $("histDetailMeta").textContent = "周期 "+id+" · "+fmtSpan(m.started_at,m.ended_at)
          +" · "+(st.frames||m.entries.length)+" 帧 · 命中 "+(st.match||0)+" · 告警 "+(st.alert||0)
          +(m.target ? " · 目标:"+m.target : " · 仅理解");
        const log = $("histLog"); log.innerHTML = "";
        m.entries.slice().reverse().forEach(e => {
          const row = document.createElement("div");
          row.className = "logrow " + (e.level||"normal");
          const thumb = e.frame_url ? `<img class="thumb" src="${e.frame_url}" alt="f"/>` : `<span class="dot"></span>`;
          row.innerHTML = `${thumb}<span class="t">${e.ts||""}</span>
            <span class="msg">${e.is_match ? '<span class="mtag">命中 </span>':''}${escapeHtml(e.msg||"")}</span>
            <span class="arrow">查看帧 ›</span>`;
          row.onclick = () => openFrameUrl(e.frame_url, e.result, e.ts);
          log.appendChild(row);
        });
      } catch(e) { alert("加载失败："+e.message); }
    }

    function fmtSpan(a,b){
      try { const s=new Date(a), en=new Date(b);
        const d = Math.max(0, Math.round((en-s)/1000));
        return s.toLocaleString("zh-CN",{hour12:false}) + " · 时长 " + d + "s";
      } catch(e) { return a||""; }
    }

    function openFrameUrl(url, res, ts){
      if (!url) return;
      $("modalImg").src = url;
      $("modalTime").textContent = "采集时间 " + (ts||"") + " · 历史归档帧 · 发送给 gpt-4o 的画面";
      $("modalJson").textContent = JSON.stringify(res||{}, null, 2);
      $("modal").classList.add("open");
    }

    function escapeHtml(s){ return (s||"").replace(/[&<>]/g, c => ({"&":"&amp;","<":"&lt;",">":"&gt;"}[c])); }

    window.addEventListener("beforeunload", stopAll);
  </script>
</body>
