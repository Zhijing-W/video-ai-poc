  <!-- ===== 技术模式视图（流程图）===== -->
  <div id="tech-view" class="view-container" style="display:none">
  <div class="canvas">
    <div class="ctitle">
      <h2>识别架构 · Live Architecture</h2>
      <span class="hint">整张图就是系统，分三栏读：<b>栏A 输入·检测·门控</b> → <b>栏B 编译·巡航·理解</b> → <b>栏C 结果·事件日志</b>。数据沿连线实时流动、点亮当前步骤；每个模块的<b>模型/方案</b>可在节点上直接切换。</span>
    </div>
    <div class="railwrap">
    <div class="diagram" id="rail">

      <!-- ===== 栏 A：输入 + 物体检测 + 事件门控 ===== -->
      <div class="dcol colA">

      <!-- 输入源 · 监控大屏 -->
      <div class="pnode din" id="nd-input" data-node="input">
        <span class="pstep">1</span>
        <div class="ph"><span class="pico">📷</span><span class="pname">输入源 · 监控画面</span><span class="pled"></span></div>
        <div class="pinline dctrl" style="flex-wrap:wrap">
          <button id="btnCam" class="pmini">📷 摄像头</button>
