# ===== Azure OpenAI（Phase 1 必填）=====
# 你自己的 Azure OpenAI / AI Foundry 资源信息，填好后复制本文件为 .env
AZURE_OPENAI_ENDPOINT=https://<your-resource>.openai.azure.com/
AZURE_OPENAI_API_KEY=<your-api-key>
AZURE_OPENAI_DEPLOYMENT=<your-vision-deployment-name>
AZURE_OPENAI_API_VERSION=2024-10-21

# ===== 抽帧参数（Phase 1 定时抽帧 / Step 7 关闭时回退用）=====
FRAME_INTERVAL_SECONDS=5
MAX_FRAMES=8
FRAME_WIDTH=768

# ===== Phase 2 · YOLO 检测 + 事件门控（Step 5/6）=====
YOLO_MODEL=yolov8m.pt
YOLO_CONF=0.4
GATE_KEY_CLASSES=person,car,truck,bus,motorcycle,bicycle,dog,cat,backpack,handbag,suitcase,knife,cell phone
GATE_COOLDOWN_MS=3000
GATE_HEARTBEAT_MS=30000

# ===== Phase 2 · 智能抽帧（Step 7：scene 突变 OR 定时兜底）=====
# SMART_FRAMES=false 则回退 FRAME_INTERVAL_SECONDS 的纯定时抽帧
SMART_FRAMES=true
SCENE_THRESHOLD=0.4
FALLBACK_INTERVAL_SECONDS=30

# ===== Blob（Step 3 可选；不填则降级为纯本地存储，API 仍可跑）=====
# 方式1（推荐，最简单）：直接给连接字符串
AZURE_STORAGE_CONNECTION_STRING=
# 方式2：给账户名 + 当前身份有 RBAC（用 DefaultAzureCredential）
AZURE_STORAGE_ACCOUNT_NAME=
AZURE_STORAGE_CONTAINER_NAME=video-understanding-poc

# ===== 可选：自定义 ffmpeg 路径（默认用 PATH 里的）=====
FFMPEG_PATH=
