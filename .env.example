# Azure OpenAI / Foundry
AZURE_OPENAI_ENDPOINT=https://<your-resource>.openai.azure.com/
AZURE_OPENAI_API_KEY=<your-api-key>
AZURE_OPENAI_DEPLOYMENT=<your-vision-deployment-name>
AZURE_OPENAI_API_VERSION=2024-10-21

# Repository-local runtime directories
DATA_DIR=data
OUTPUT_DIR=out
GALLERY_DIR=gallery

# Detection and tracking
YOLO_MODEL=models/yolov8m.pt
POSE_MODEL=models/yolov8n-pose.pt
GAIT_SEG_MODEL=models/yolov8m-seg.pt
YOLO_CONF=0.4
TRACK_BACKEND=botsort_reid
REID_BACKEND=auto

# Optional face providers
FACE_DEVICE=auto
FACE_MODEL=buffalo_l
FACE_REC_BACKEND=adaface
FACE_ADAFACE_ROOT=models/AdaFace
FACE_ADAFACE_WEIGHTS=models/AdaFace/pretrained/pretrained_model/model.pt
FACE_SUPERRES=gfpgan
FACE_GFPGAN_WEIGHTS=

# Optional gait provider
GAIT_ENABLED=true
GAIT_DEVICE=cpu
GAIT_OPENGAIT_ROOT=models/OpenGait
GAIT_CKPT=models/OpenGait/checkpoints/GREW/SkeletonGaitPP/SkeletonGaitPP/checkpoints/SkeletonGaitPP-180000.pt

# Optional scene providers
OCR_ENABLED=false
OBJECT_DETECT=false

# Event analysis
EVENT_LLM_DEPLOYMENT=
EVENT_WINDOW_MAX_SECONDS=30
EVENT_OVERALL_SUMMARY=1

# ffmpeg executable; leave empty to use PATH
FFMPEG_PATH=
