# Azure OpenAI / Foundry
AZURE_OPENAI_ENDPOINT=https://<your-resource>.openai.azure.com/
AZURE_OPENAI_API_KEY=<your-api-key>
AZURE_OPENAI_DEPLOYMENT=<your-vision-deployment-name>
AZURE_OPENAI_API_VERSION=2024-10-21

# Repository-local runtime directories
DATA_DIR=data

# Detection, tracking, and body ReID
YOLO_MODEL=models/yolov8m.pt
POSE_MODEL=models/yolov8n-pose.pt
YOLO_CONF=0.4
TRACK_BACKEND=botsort_reid
REID_BACKEND=auto
REID_DEVICE=auto

# Frame selection and LLM gate
SMART_FRAMES=true
SCENE_THRESHOLD=0.4
FALLBACK_INTERVAL_SECONDS=30
GATE_COOLDOWN_MS=3000
GATE_HEARTBEAT_MS=30000

# Optional Blob archive
AZURE_STORAGE_CONNECTION_STRING=
AZURE_STORAGE_ACCOUNT_NAME=
AZURE_STORAGE_CONTAINER_NAME=video-understanding-poc

# ffmpeg executable; leave empty to use PATH
FFMPEG_PATH=
